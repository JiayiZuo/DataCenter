# .env.example
LOG_LEVEL=INFO

EVIDENCE_BASE_URL=http://your-evidence-host:port
CHAIN_ID=your-chain-id
EVIDENCE_API_KEY=your-api-key-here
EVIDENCE_IDENTITY_ID=your-identity-id-here
EVIDENCE_COOKIE=Secure

INVENTORY_BASE_URL=http://your-inventory-host:port
INVENTORY_TOKEN=your-jwt-token-here

OUTPUT_DIR=./output
BATCH_SIZE=10
REQUEST_TIMEOUT=30
MAX_RETRIES=3